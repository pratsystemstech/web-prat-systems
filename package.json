:root {
  --bg: #0b1020;
  --bg-soft: #11182e;
  --text: #0f172a;
  --muted: #5b6474;
  --line: #d7dde7;
  --white: #ffffff;
  --primary: #111827;
  --accent: #2563eb;
  --surface: #ffffff;
  --surface-soft: #f5f7fb;
  --shadow: 0 20px 45px rgba(15, 23, 42, 0.08);
  --radius: 22px;
}

* { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  margin: 0;
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  color: var(--text);
  background: var(--white);
}

a { color: inherit; text-decoration: none; }
button, input, select, textarea {
  font: inherit;
}

.container {
  width: min(1180px, calc(100% - 2rem));
  margin: 0 auto;
}

.section {
  padding: 88px 0;
}

.muted {
  background: var(--surface-soft);
}

.header {
  position: sticky;
  top: 0;
  z-index: 30;
  background: rgba(255,255,255,0.9);
  border-bottom: 1px solid rgba(215,221,231,0.8);
  backdrop-filter: blur(12px);
}

.nav-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 74px;
  gap: 20px;
}

.brand {
  font-weight: 800;
  letter-spacing: 0.04em;
}

.nav {
  display: flex;
  gap: 24px;
  color: var(--muted);
}

.nav a:hover { color: var(--text); }

.menu-btn {
  display: none;
  border: 1px solid var(--line);
  background: var(--white);
  border-radius: 12px;
  padding: 8px 12px;
}

.hero {
  padding-top: 64px;
}

.hero-grid {
  display: grid;
  grid-template-columns: 1.15fr 0.85fr;
  gap: 36px;
  align-items: center;
}

.eyebrow {
  display: inline-block;
  padding: 8px 12px;
  background: #e8eefc;
  color: #1d4ed8;
  border-radius: 999px;
  font-size: 0.85rem;
  font-weight: 700;
  margin-bottom: 18px;
}

.eyebrow.light {
  background: rgba(255,255,255,0.12);
  color: #dbeafe;
}

h1, h2, h3, p { margin: 0; }

h1 {
  font-size: clamp(2.5rem, 5vw, 4.6rem);
  line-height: 0.98;
  letter-spacing: -0.05em;
  margin-bottom: 18px;
}

h2 {
  font-size: clamp(2rem, 4vw, 3rem);
  line-height: 1.04;
  letter-spacing: -0.04em;
  margin-bottom: 14px;
}

h3 {
  font-size: 1.2rem;
  line-height: 1.2;
  margin-bottom: 10px;
}

p {
  line-height: 1.7;
  color: var(--muted);
}

.lead {
  max-width: 650px;
  font-size: 1.1rem;
  margin-bottom: 24px;
}

.hero-actions {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  margin-bottom: 28px;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 48px;
  padding: 0 18px;
  border-radius: 14px;
  font-weight: 700;
  transition: transform .18s ease, box-shadow .18s ease, background .18s ease;
  border: 1px solid transparent;
}

.btn:hover {
  transform: translateY(-1px);
}

.btn-primary {
  background: var(--primary);
  color: var(--white);
  box-shadow: var(--shadow);
}

.btn-secondary {
  background: var(--white);
  color: var(--text);
  border-color: var(--line);
}

.btn-light {
  background: var(--white);
  color: var(--bg);
}

.card {
  background: var(--surface);
  border: 1px solid rgba(215,221,231,0.9);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}

.flow-box {
  padding: 24px;
  background: linear-gradient(180deg, #101829 0%, #0b1020 100%);
  color: var(--white);
}

.flow-step {
  border: 1px solid rgba(255,255,255,0.12);
  background: rgba(255,255,255,0.06);
  padding: 16px;
  border-radius: 16px;
  text-align: center;
  font-weight: 700;
}

.flow-arrow {
  text-align: center;
  opacity: 0.8;
  padding: 8px 0;
}

.kpis {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

.stat {
  padding: 18px;
}

.stat strong {
  display: block;
  font-size: 1.2rem;
  margin-bottom: 6px;
}

.stat span {
  color: var(--muted);
  font-size: 0.95rem;
}

.section-title {
  max-width: 780px;
  margin-bottom: 34px;
}

.section-title.center {
  text-align: center;
  margin-inline: auto;
  margin-bottom: 40px;
}

.grid {
  display: grid;
  gap: 18px;
}

.cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
.cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }

.soft-card,
.service-card,
.step-card,
.demo-card,
.form-card {
  padding: 24px;
}

.service-card p,
.demo-card p { margin-top: 8px; }

.demo-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
  margin-top: 16px;
}

.form-grid.compact {
  margin-bottom: 16px;
}

label {
  display: grid;
  gap: 8px;
  font-weight: 600;
  color: var(--text);
}

input,
select,
textarea {
  width: 100%;
  border-radius: 14px;
  border: 1px solid var(--line);
  background: var(--white);
  min-height: 46px;
  padding: 0 14px;
  color: var(--text);
}

textarea {
  min-height: auto;
  padding: 14px;
  resize: vertical;
}

.slider-group {
  display: grid;
  gap: 14px;
  margin-top: 16px;
  margin-bottom: 16px;
}

input[type='range'] {
  padding: 0;
}

.result-box {
  padding: 18px;
  border-radius: 18px;
  background: #f8fafc;
  border: 1px solid var(--line);
}

.result-box strong {
  display: block;
  margin-bottom: 6px;
  font-size: 1.05rem;
}

.result-box span {
  display: block;
  margin-top: 10px;
  font-size: 0.95rem;
  color: #334155;
}

.mini-flow {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10px;
  margin: 18px 0 14px;
}

.mini-flow div,
.mini-flow span {
  padding: 12px 14px;
  border-radius: 14px;
  background: #f8fafc;
  border: 1px solid var(--line);
}

.feature-list {
  padding-left: 18px;
  color: var(--muted);
}

.feature-list li + li {
  margin-top: 8px;
}

.step-number {
  display: inline-flex;
  width: 38px;
  height: 38px;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  background: #e8eefc;
  color: #1d4ed8;
  font-weight: 800;
  margin-bottom: 12px;
}

.cta-band {
  background: linear-gradient(180deg, #0f172a 0%, #111827 100%);
  color: var(--white);
}

.cta-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}

.cta-band p,
.footer p { color: rgba(255,255,255,0.72); }

.contact-grid {
  display: grid;
  grid-template-columns: 0.9fr 1.1fr;
  gap: 18px;
  align-items: start;
}

.contact-cards {
  display: grid;
  gap: 12px;
  margin-top: 20px;
}

.contact-cards .soft-card {
  display: grid;
  gap: 6px;
}

.form-card {
  display: grid;
  gap: 14px;
}

.form-card small {
  color: var(--muted);
}

.footer {
  background: #0b1020;
  color: var(--white);
  padding: 28px 0;
}

.footer-wrap {
  display: flex;
  justify-content: space-between;
  gap: 20px;
  align-items: center;
}

.footer-links {
  display: flex;
  gap: 18px;
  color: rgba(255,255,255,0.74);
}

@media (max-width: 980px) {
  .hero-grid,
  .contact-grid,
  .cta-wrap,
  .cols-4,
  .cols-3,
  .demo-grid {
    grid-template-columns: 1fr;
  }

  .kpis,
  .form-grid {
    grid-template-columns: 1fr;
  }

  .nav {
    display: none;
    position: absolute;
    top: 74px;
    left: 0;
    right: 0;
    background: rgba(255,255,255,0.98);
    border-bottom: 1px solid var(--line);
    padding: 18px 1rem;
    flex-direction: column;
  }

  .nav.nav-open {
    display: flex;
  }

  .menu-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .footer-wrap {
    flex-direction: column;
    align-items: flex-start;
  }
}
